{
  "manifest_version": 3,
  "name": "LeadPilot AI — Premium Lead Intelligence",
  "version": "1.0.0",
  "description": "Legal, ToS-clean lead intelligence for Google Maps. Places API (New), live 0-100 lead score, temperature signals, and multi-format export (XLSX / CSV / JSON).",
  "action": {
    "default_title": "LeadPilot AI",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "options_page": "options.html",
  "permissions": ["storage", "sidePanel"],
  "host_permissions": [
    "https://places.googleapis.com/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}

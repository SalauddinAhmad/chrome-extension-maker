{
  "manifest_version": 3,
  "name": "Durud Reminder",
  "version": "2.0.0",
  "description": "মিনিমাল ও এলিগ্যান্ট দুরুদ রিমাইন্ডার — তাসবিহ কাউন্টার, স্ট্রিক, সমৃদ্ধ দুরুদ লাইব্রেরি, অডিও তিলাওয়াত ও স্মার্ট নোটিফিকেশন।",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["alarms", "storage", "notifications", "idle", "offscreen"],
  "web_accessible_resources": [
    {
      "resources": ["assets/audios/*.mp3", "offscreen.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

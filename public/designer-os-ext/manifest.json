{
  "manifest_version": 3,
  "name": "Designer OS",
  "short_name": "Designer OS",
  "version": "1.0.0",
  "description": "The Open-Source Creative Workspace for Designers. No account. No subscription. No server. No tracking. Everything runs inside your browser.",
  "author": "Designer OS Contributors",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "Designer OS",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "sidepanel/index.html"
  },

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/design-extractor.js",
        "content/font-detector.js",
        "content/tech-detector.js",
        "content/screenshot-cropper.js",
        "content/downloader.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "unlimitedStorage",
    "downloads",
    "alarms",
    "notifications"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+D",
        "mac": "Alt+D"
      },
      "description": "Open Designer OS Popup"
    }
  },

  "web_accessible_resources": [
    {
      "resources": [
        "sidepanel/*",
        "modules/*",
        "libs/*",
        "data/*",
        "icons/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
